<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WeatherStation.ViewModels"
             x:Class="WeatherStation.Views.DeviceView"
             x:DataType="vm:DeviceViewModel">
  <Grid RowDefinitions="Auto,*" Margin="8">

    <!-- 设备添加卡片 -->
    <Border Grid.Row="0" Background="{DynamicResource SystemRegionBrush}" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000" Margin="0,0,0,16">
      <StackPanel Spacing="16">
        <TextBlock Text="新增设备" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto" Margin="0,8,0,0">
          <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="设备名称" FontWeight="SemiBold" Margin="0,0,12,0" />
          <TextBox Grid.Column="1" Text="{Binding DeviceName}" Watermark="例如: 室外传感器1" Margin="0,0,24,0" />

          <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="设备编号" FontWeight="SemiBold" Margin="0,0,12,0" />
          <TextBox Grid.Column="3" Text="{Binding DeviceNo}" Watermark="例如: DEV001" Margin="0,0,24,0" />

          <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="部署位置" FontWeight="SemiBold" Margin="0,0,12,0" />
          <TextBox Grid.Column="5" Text="{Binding Location}" Watermark="例如: 楼顶北侧" />
        </Grid>

        <Button HorizontalAlignment="Left" Content="➕ 添加到系统" Command="{Binding AddCommand}"
                Background="#107C10" Foreground="White" Padding="20,8" CornerRadius="6" />
      </StackPanel>
    </Border>

    <!-- 设备列表卡片 -->
    <Border Grid.Row="1" Background="{DynamicResource SystemRegionBrush}" CornerRadius="12" Padding="20" BoxShadow="0 2 8 0 #10000000">
      <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
          <TextBlock Text="设备列表" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
          <Button Content="🔄 刷新列表" Command="{Binding LoadCommand}" Margin="16,0,0,0" Padding="12,6" />
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}" AutoGenerateColumns="True" IsReadOnly="True"
                  BorderBrush="#20000000" BorderThickness="1" CornerRadius="8" Background="Transparent" />

        <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="{Binding Status}" Opacity="0.7" FontSize="13" />
      </Grid>
    </Border>

  </Grid>
</UserControl>
