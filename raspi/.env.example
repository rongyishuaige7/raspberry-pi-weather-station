# Copy this file to raspi/.env. Keep raspi/.env out of Git and load it only on
# a trusted development machine or Raspberry Pi. Do not use these placeholders
# as real credentials.
MYSQL_HOST=127.0.0.1
# Set MYSQL_PORT=13306 when using this repository's optional Docker Compose
# integration database. Keep 3306 for a directly installed local MySQL.
MYSQL_PORT=3306
MYSQL_DATABASE=weather_station
MYSQL_USER=replace_with_local_user
MYSQL_PASSWORD=replace_with_a_long_unique_database_password
MYSQL_ROOT_PASSWORD=replace_with_a_long_unique_root_password
# Generate at least 32 random characters for the Flask JWT signing key.
JWT_SECRET=replace_with_at_least_32_random_characters
# Required only when intentionally creating an initial administrator.
ADMIN_USER=replace_with_admin_username
ADMIN_PASS=replace_with_at_least_12_random_characters
# Optional local API binding. Keep loopback by default; use a trusted LAN IP
# only after documenting the network boundary.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
